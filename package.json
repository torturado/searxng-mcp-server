{
	"name": "searxng-mcp-server",
	"version": "0.1.0",
	"type": "module",
	"description": "MCP server for SearXNG with stdio and Streamable HTTP transports.",
	"license": "MIT",
	"keywords": [
		"mcp",
		"modelcontextprotocol",
		"searxng",
		"search",
		"typescript"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev:stdio": "tsx src/index.ts",
		"dev:http": "tsx src/http.ts",
		"start": "node dist/index.js",
		"start:stdio": "node dist/index.js",
		"start:http": "node dist/http.js"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^25.3.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
